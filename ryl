-- [ 3. CORE LOGIC ] --
local TargetPlayer = nil
local Mode = ""
local IsActive = false
local Angle = 0

local function GetPlayer(S)
    if S == "" then return nil end
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():sub(1,#S) == S:lower() or v.DisplayName:lower():sub(1,#S) == S:lower() then return v end
    end
end

FrontBtn.MouseButton1Click:Connect(function()
    TargetPlayer = GetPlayer(TargetInput.Text)
    if TargetPlayer then Mode = "Front" IsActive = true Player.Character.Humanoid.Sit = true end
end)

BackBtn.MouseButton1Click:Connect(function()
    TargetPlayer = GetPlayer(TargetInput.Text)
    if TargetPlayer then Mode = "Back" IsActive = true Player.Character.Humanoid.Sit = true end
end)

StopBtn.MouseButton1Click:Connect(function() 
    IsActive = false 
    Mode = "" 
    if Player.Character:FindFirstChild("Humanoid") then Player.Character.Humanoid.Sit = false end
    if Player.Character:FindFirstChild("HumanoidRootPart") then Player.Character.HumanoidRootPart.Velocity = Vector3.new(0,0,0) end
end)

AntiBangBtn.MouseButton1Click:Connect(function()
    local hrp = Player.Character.HumanoidRootPart
    workspace.FallenPartsDestroyHeight = -1000
    local lastCF = hrp.CFrame
    hrp.CFrame = CFrame.new(0, -500, 0)
    task.wait(0.7)
    hrp.CFrame = lastCF
    workspace.FallenPartsDestroyHeight = -500
end)

RunService.RenderStepped:Connect(function()
    if IsActive and TargetPlayer and TargetPlayer.Character and Player.Character then
        local MyRoot = Player.Character:FindFirstChild("HumanoidRootPart")
        local TheirRoot = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if MyRoot and TheirRoot then
            local Speed = tonumber(SpeedInput.Text) or 25
            Angle = Angle + (Speed / 10)
            local MoveOffset = math.sin(Angle) * 1.5
            
            if Mode == "Front" then
                -- Height set to 0.9 as requested
                MyRoot.CFrame = TheirRoot.CFrame * CFrame.new(0, 0.9, -1.1) * CFrame.Angles(0, math.pi, 0) * CFrame.new(0, 0, MoveOffset)
            elseif Mode == "Back" then
                MyRoot.CFrame = TheirRoot.CFrame * CFrame.new(0, 0.9, 1.1) * CFrame.new(0, 0, MoveOffset)
            end
            MyRoot.Velocity = Vector3.new(0,0,0)
        end
    end
end)
