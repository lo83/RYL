-- [[ 3. CORE LOGIC ]] --
local RunService = game:GetService("RunService")
local TargetPlayer = nil
local Mode = ""
local IsActive = false
local Angle = 0

local function GetPlayer(S)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():sub(1,#S) == S:lower() or v.DisplayName:lower():sub(1,#S) == S:lower() then return v end
    end
end

AntiBangBtn.MouseButton1Click:Connect(function()
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        workspace.FallenPartsDestroyHeight = -1000
        local lastCF = hrp.CFrame
        hrp.CFrame = CFrame.new(Vector3.new(0, -500, 0))
        task.wait(0.7)
        hrp.CFrame = lastCF
        workspace.FallenPartsDestroyHeight = -500
    end
end)

