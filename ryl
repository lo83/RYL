-- [[ 3. Core Logic ]] --
local RunService = game:GetService("RunService")
local TargetPlayer = nil
local Mode = ""
local IsActive = false
local Angle = 0

local function GetPlayer(S)
    for _, v in pairs(game.Players:GetPlayers()) do
        if string.sub(v.Name:lower(),1,#S) == S:lower() or string.sub(v.DisplayName:lower(),1,#S) == S:lower() then return v end
    end
end

-- فەنکشنا Anti-Bang
AntiBangBtn.MouseButton1Click:Connect(function()
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        workspace.FallenPartsDestroyHeight = -1000
        local lastCFrame = hrp.CFrame
        hrp.CFrame = CFrame.new(Vector3.new(0, -500, 0))
        task.wait(0.7)
        hrp.CFrame = lastCFrame
        workspace.FallenPartsDestroyHeight = -500
    end
end)

FrontBtn.MouseButton1Click:Connect(function()
    TargetPlayer = GetPlayer(TargetInput.Text)
    if TargetPlayer then 
        Mode = "Front" IsActive = true 
        Player.Character.Humanoid.Sit = true
        Camera.CameraSubject = nil 
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("مص", "All")
    end
end)

BackBtn.MouseButton1Click:Connect(function()
    TargetPlayer = GetPlayer(TargetInput.Text)
    if TargetPlayer then 
        Mode = "Back" IsActive = true 
        Player.Character.Humanoid.Sit = true
        Camera.CameraSubject = nil
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer("مص", "All")
    end
end)

StopBtn.MouseButton1Click:Connect(function()
    IsActive = false
    Mode = ""
    Camera.CameraSubject = Player.Character.Humanoid
    if Player.Character and Player.Character:FindFirstChild("Humanoid") then Player.Character.Humanoid.Sit = false end
end)

RunService.RenderStepped:Connect(function()
    if IsActive and TargetPlayer and TargetPlayer.Character and Player.Character then
        local MyRoot = Player.Character:FindFirstChild("HumanoidRootPart")
        local TheirRoot = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if MyRoot and TheirRoot then
            local Speed = tonumber(SpeedInput.Text) or 15
            Angle = Angle + (Speed / 10)
            local MoveOffset = math.sin(Angle) * 0.7
            
            if Mode == "Front" then
                MyRoot.CFrame = TheirRoot.CFrame * CFrame.new(0, 1.1, -1.2) * CFrame.Angles(0, math.pi, 0) * CFrame.new(0, 0, MoveOffset)
            elseif Mode == "Back" then
                MyRoot.CFrame = TheirRoot.CFrame * CFrame.new(0, -0.2, 1.2) * CFrame.new(0, 0, MoveOffset)
            end
            MyRoot.Velocity = Vector3.new(0, 0, 0)
        end
    end
end)

